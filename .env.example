# Skip introduction animations on load (true/false)
VITE_SKIP_INTRO=true

# Target component ID for automatic scroll on load (e.g. experience)
# Leave empty to start at the top
VITE_START_POSITION=experience

# Enable dev configuration overrides (true/false, default: true)
VITE_DEV_ENABLED=true

# Resume game state from localStorage snapshot in dev mode (true/false, default: false)
VITE_RESUME_FROM_SNAPSHOT=false

# Initial scene ID to start the game directly at a specific scene
# e.g., dayOnePartySexy
VITE_INITIAL_SCENE_ID=

# Initial energy amount for testing (default: 100)
VITE_INITIAL_ENERGY=100

# Initial outfit choice for testing (e.g., sexy, default: sexy)
VITE_INITIAL_OUTFIT=sexy

# Playback rate for audio in dev (default: 1)
VITE_PLAYBACK_RATE=1

# Credits links
NUXT_PUBLIC_CREDITS_DEVELOPMENT=https://ismaelsebbane.fr
NUXT_PUBLIC_CREDITS_DESIGN=https://anabanana.fr

# URL to conditionally show DevTools in production
NUXT_PUBLIC_TEST_URL=netlify.app
